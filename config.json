{
  "mcp_servers": [
    {
      "name": "everything",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    {
      "name": "wolfram",
      "transport": "streamable-http",
      "url": "https://services.wolfram.com/api/mcp",
      "headers": {
        "Authorization": "Bearer ${WOLFRAM_API_KEY}"
      }
    },
    {
      "name": "kohya-lora-training",
      "transport": "streamable-http",
      "url": "${KOHYA_MCP_URL}"
    },
    {
      "name": "connectome",
      "transport": "streamable-http",
      "url": "http://connectome-mcp:3100/mcp"
    },
    {
      "name": "glitchtip",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-glitchtip"
      ],
      "env": {
        "GLITCHTIP_BASE_URL": "http://glitchtip:8080",
        "GLITCHTIP_TOKEN": "${GLITCHTIP_API_TOKEN}",
        "GLITCHTIP_ORGANIZATION": "connectome"
      }
    }
  ],
  "tool_configs": [
    {
      "type": "http",
      "name": "fetch",
      "description": "Fetch content from a URL. Use this to retrieve web pages, APIs, or any HTTP-accessible content."
    },
    {
      "type": "cli",
      "name": "polymarket",
      "binary": "polymarket",
      "description": "Query Polymarket prediction markets. Key commands:\n- markets list [--limit N] [--active true]\n- markets search <query> [--limit N]\n- markets get <id-or-slug>\n- events list [--tag TAG] [--limit N]\n- events get <id>\n- clob price <token_id> --side buy|sell\n- clob midpoint <token_id>\n- clob book <token_id>\n- clob price-history <token_id> --interval 1d --fidelity 100\n- data leaderboard [--period month] [--limit N]\n- tags list\n- sports list\nAll output is JSON.",
      "default_args": [
        "-o",
        "json"
      ],
      "allowed_subcommands": [
        "markets",
        "events",
        "clob",
        "data",
        "tags",
        "series",
        "comments",
        "profiles",
        "sports",
        "status"
      ],
      "timeout_ms": 30000
    },
    {
      "type": "terminal",
      "name": "terminal",
      "description": "Execute shell commands locally or on remote compute hosts. IMPORTANT: Always use the host parameter to run on remote machines — never use raw ssh commands, because Tailscale hostnames cannot be resolved from inside this container. The host parameter handles SSH routing automatically. Use background=true and pty=true for interactive CLI agents (Claude Code, Codex). Use the process tool to monitor background processes. Note: this container has a read-only filesystem — only /workspace/shared/, /tmp/, and /home/coder/ are writable.",
      "default_cwd": "/workspace/shared",
      "timeout_ms": 120000,
      "max_output_chars": 50000
    },
    {
      "type": "terminal",
      "name": "process",
      "description": "Manage background processes. Actions: list (show all), poll (check status + recent output), log (read full output, optional lines param), submit (send input + Enter), kill (terminate)."
    },
    {
      "type": "delegate",
      "name": "delegate",
      "description": "Delegate a task to another bot. Use target_bot for a specific bot (e.g. \"claude-sonnet-4-6\"), or capabilities for capability-based routing. Use workspace to create a shared project space at /workspace/shared/{workspace}/."
    }
  ],
  "bots": [
    {
      "name": "claude-opus-4-6",
      "model": "claude-opus-4-6",
      "prompt": "Standard",
      "max_tokens": 16384,
      "mcp": ["kohya-lora-training", "connectome"],
      "tools": [
        "fetch",
        "polymarket",
        "terminal",
        "process",
        "delegate"
      ],
      "skill_paths": [
        "/workspace/skills/connectome-ontology",
        "/workspace/skills/agent-spawning/claude-code",
        "/workspace/skills/agent-spawning/collaboration",
        "/workspace/skills/agent-spawning/coordination",
        "/workspace/skills/autoresearch",
        "/workspace/skills/economic-operations"
      ],
      "rlm": {
        "maxDepth": 2,
        "maxCalls": 10,
        "timeoutSeconds": 300

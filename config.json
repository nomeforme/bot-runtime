{
  "mcp_servers": [
    {
      "name": "everything",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"]
    },
    {
      "name": "wolfram",
      "transport": "streamable-http",
      "url": "https://services.wolfram.com/api/mcp",
      "headers": {
        "Authorization": "Bearer ${WOLFRAM_API_KEY}"
      }
    }
  ],
  "tool_configs": [
    {
      "type": "http",
      "name": "fetch",
      "description": "Fetch content from a URL. Use this to retrieve web pages, APIs, or any HTTP-accessible content."
    },
    {
      "type": "cli",
      "name": "polymarket",
      "binary": "polymarket",
      "description": "Query Polymarket prediction markets. Key commands:\n- markets list [--limit N] [--active true]\n- markets search <query> [--limit N]\n- markets get <id-or-slug>\n- events list [--tag TAG] [--limit N]\n- events get <id>\n- clob price <token_id> --side buy|sell\n- clob midpoint <token_id>\n- clob book <token_id>\n- clob price-history <token_id> --interval 1d --fidelity 100\n- data leaderboard [--period month] [--limit N]\n- tags list\n- sports list\nAll output is JSON.",
      "default_args": ["-o", "json"],
      "allowed_subcommands": ["markets", "events", "clob", "data", "tags", "series", "comments", "profiles", "sports", "status"],
      "timeout_ms": 30000
    },
    {
      "type": "terminal",
      "name": "terminal",
      "description": "Execute shell commands. Use background=true and pty=true for interactive CLI agents (Claude Code, Codex). Use the process tool to monitor background processes.",
      "default_cwd": "/workspace/shared",
      "timeout_ms": 120000,
      "max_output_chars": 50000
    },
    {
      "type": "terminal",
      "name": "process",
      "description": "Manage background processes. Actions: list (show all), poll (check status + recent output), log (read full output, optional lines param), submit (send input + Enter), kill (terminate)."
    },
    {
      "type": "delegate",
      "name": "delegate",
      "description": "Delegate a task to another bot. Use target_bot for a specific bot (e.g. \"claude-sonnet-4-6\"), or capabilities for capability-based routing. Use workspace to create a shared project space at /workspace/shared/{workspace}/."
    }
  ],
  "bots": [
    {
      "name": "claude-opus-4-6",
      "model": "claude-opus-4-6",
      "prompt": "Standard",
      "max_tokens": 1024,
      "tools": ["fetch", "polymarket", "terminal", "process", "delegate"],
      "mcp": ["everything", "wolfram"],
      "skill_paths": [
        "/workspace/skills/connectome-ontology",
        "/workspace/pi-skills/brave-search",
        "/workspace/skills/agent-spawning/claude-code",
        "/workspace/skills/agent-spawning/collaboration",
        "/workspace/skills/agent-spawning/coordination"
      ],
      "rlm": {
        "maxDepth": 2,
        "maxCalls": 10,
        "timeoutSeconds": 300
      }
    },
    {
      "name": "claude-sonnet-4-6",
      "model": "claude-sonnet-4-6",
      "prompt": "Standard",
      "max_tokens": 1024,
      "tools": ["fetch", "terminal", "process", "delegate"],
      "mcp": ["everything"],
      "skill_paths": [
        "/workspace/skills/connectome-ontology",
        "/workspace/pi-skills/brave-search",
        "/workspace/skills/agent-spawning/claude-code",
        "/workspace/skills/agent-spawning/collaboration",
        "/workspace/skills/agent-spawning/coordination"
      ]
    },
    {
      "name": "claude-3-opus",
      "model": "claude-3-opus-20240229",
      "prompt": "Standard",
      "max_tokens": 1024,
      "tools": [],
      "skip_identity_prompt": false
    },
    {
      "name": "claude-3-sonnet",
      "model": "us.anthropic.claude-3-sonnet-20240229-v1:0",
      "prompt": "Standard",
      "max_tokens": 1024,
      "prompt_caching": false,
      "tools": ["fetch"]
    },
    {
      "name": "claude-sonnet-4-5",
      "model": "claude-sonnet-4-5-20250929",
      "prompt": "Standard",
      "max_tokens": 1024,
      "tools": ["fetch", "terminal", "process", "delegate"],
      "skill_paths": [
        "/workspace/skills/connectome-ontology",
        "/workspace/pi-skills/brave-search",
        "/workspace/skills/agent-spawning/claude-code",
        "/workspace/skills/agent-spawning/collaboration",
